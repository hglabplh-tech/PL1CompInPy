DCL LENGTH BUILTIN;
DCL INDEX BUILTIN;
DCL ABS BUILTIN;
DCL MIN BUILTIN;
DCL MAX BUILTIN;
DCL MOD BUILTIN;
DCL ROUND BUILTIN;
DCL TRUNC BUILTIN;

DCL TEXT CHARACTER;
DCL A FIXED BIN(31);
DCL B FIXED BIN(31);

TEXT = 'HELLO BUILTINS';
A = 42;
B = 5;

CALL LENGTH(TEXT);
CALL INDEX(TEXT, 'BUILD');
CALL ABS(A);
CALL MIN(A, B, 100);
CALL MAX(A, B, 100);
CALL MOD(A, B);
CALL ROUND(123.456, 2);
CALL TRUNC(123.456, 2);
